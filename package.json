{
  "name": "sullivan-county-tn",
  "version": "1.0.0",
  "description": "Official government website for Sullivan County, Tennessee. TanStack Start + Cloudflare Workers + shadcn/ui + NWS weather + PWA.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "generate:sitemap": "tsx scripts/generate-sitemap.ts",
    "generate:rss": "tsx scripts/generate-rss.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-separator": "^1.1.8",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-start": "^1.167.64",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "fuse.js": "^7.3.0",
    "i18next": "^25.10.10",
    "lucide-react": "^0.575.0",
    "next-themes": "^0.4.6",
    "qrcode-svg": "^1.1.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^16.6.6",
    "sanitize-html": "^2.17.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "ulidx": "^2.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.14",
    "@cloudflare/vite-plugin": "*",
    "@cloudflare/vitest-pool-workers": "^0.16.6",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "*",
    "@types/react": "*",
    "@types/react-dom": "*",
    "@types/sanitize-html": "^2.16.0",
    "@vitejs/plugin-react": "^5.1.4",
    "drizzle-kit": "^0.31.9",
    "jsdom": "^28.1.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "*",
    "tw-animate-css": "^1.4.0",
    "typescript": "*",
    "vite": "*",
    "vite-tsconfig-paths": "*",
    "vitest": "^4.1.5",
    "wrangler": "*"
  }
